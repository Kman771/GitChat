# Copy this file to .env and fill in your values.
# .env is gitignored — never commit your actual secrets.

# PostgreSQL connection string.
# Format: postgresql://<your-mac-username>@localhost:5432/repo_rag
DATABASE_URL=postgresql://your_mac_username@localhost:5432/repo_rag

# Anthropic API key — get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override Ollama embed endpoint (default shown)
# OLLAMA_URL=http://localhost:11434/api/embed
